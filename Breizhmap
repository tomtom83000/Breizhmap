<!DOCTYPE html><html lang="fr">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>BreizhMap</title> 
  <link rel="stylesheet" href="https://unpkg.com/leaflet@1.9.4/dist/leaflet.css" />
  <link rel="stylesheet" href="https://unpkg.com/leaflet.markercluster@1.5.3/dist/MarkerCluster.css" />
  <link rel="stylesheet" href="https://unpkg.com/leaflet.markercluster@1.5.3/dist/MarkerCluster.Default.css" />  <style>
    :root {
      --bg: #eef3ea;
      --panel: rgba(255,255,255,0.92);
      --text: #183026;
      --muted: #5d7367;
      --border: rgba(24,48,38,0.12);
      --blue: #2563eb;
      --green: #16a34a;
      --orange: #f97316;
      --red: #dc2626;
      --shadow: 0 10px 30px rgba(0,0,0,0.12);
      --radius: 18px;
    }

    * { box-sizing: border-box; }

    html, body {
      margin: 0;
      padding: 0;
      width: 100%;
      height: 100%;
      font-family: Inter, Arial, sans-serif;
      background: var(--bg);
      color: var(--text);
    }

    #app {
      width: 100%;
      height: 100%;
      position: relative;
      overflow: hidden;
    }

    #map {
      width: 100%;
      height: 100%;
    }

    .topbar {
      position: absolute;
      top: 14px;
      left: 14px;
      right: 14px;
      z-index: 1000;
      display: flex;
      gap: 10px;
      align-items: center;
      justify-content: space-between;
      pointer-events: none;
    }

    .brand,
    .actions,
    .legend,
    .sidepanel,
    .modal {
      pointer-events: auto;
    }

    .brand {
      display: inline-flex;
      align-items: center;
      gap: 10px;
      padding: 12px 14px;
      background: var(--panel);
      border: 1px solid var(--border);
      border-radius: 999px;
      box-shadow: var(--shadow);
      backdrop-filter: blur(12px);
      max-width: calc(100vw - 160px);
    }

    .brand h1 {
      margin: 0;
      font-size: 18px;
      line-height: 1;
    }

    .brand small {
      display: block;
      color: var(--muted);
      font-size: 11px;
      margin-top: 3px;
    }

    .actions {
      display: flex;
      gap: 8px;
    }

    button {
      border: none;
      border-radius: 999px;
      padding: 12px 16px;
      font-size: 14px;
      font-weight: 600;
      cursor: pointer;
      box-shadow: var(--shadow);
    }

    .btn-primary {
      background: #1f6b4f;
      color: white;
    }

    .btn-secondary {
      background: var(--panel);
      color: var(--text);
      border: 1px solid var(--border);
    }

    .legend {
      position: absolute;
      bottom: 18px;
      left: 14px;
      z-index: 1000;
      background: var(--panel);
      border: 1px solid var(--border);
      border-radius: var(--radius);
      box-shadow: var(--shadow);
      padding: 12px 14px;
      min-width: 190px;
      backdrop-filter: blur(12px);
    }

    .legend h3,
    .sidepanel h3 {
      margin: 0 0 10px;
      font-size: 14px;
    }

    .legend-item {
      display: flex;
      align-items: center;
      gap: 10px;
      margin: 7px 0;
      color: var(--text);
      font-size: 13px;
    }

    .dot {
      width: 12px;
      height: 12px;
      border-radius: 50%;
      flex: 0 0 auto;
    }

    .blue { background: var(--blue); }
    .green { background: var(--green); }
    .orange { background: var(--orange); }
    .red { background: var(--red); }

    .sidepanel {
      position: absolute;
      top: 78px;
      right: 14px;
      bottom: 18px;
      width: min(360px, calc(100vw - 28px));
      background: var(--panel);
      border: 1px solid var(--border);
      border-radius: 24px;
      box-shadow: var(--shadow);
      z-index: 1000;
      padding: 14px;
      display: flex;
      flex-direction: column;
      backdrop-filter: blur(12px);
    }

    .filters {
      display: flex;
      gap: 8px;
      flex-wrap: wrap;
      margin-bottom: 12px;
    }

    .chip {
      padding: 8px 12px;
      border-radius: 999px;
      border: 1px solid var(--border);
      background: white;
      font-size: 12px;
      cursor: pointer;
    }

    .chip.active {
      background: #1f6b4f;
      color: white;
      border-color: #1f6b4f;
    }

    .spot-list {
      overflow: auto;
      display: flex;
      flex-direction: column;
      gap: 10px;
      padding-right: 2px;
    }

    .spot-card {
      border: 1px solid var(--border);
      border-radius: 16px;
      background: rgba(255,255,255,0.9);
      padding: 12px;
      cursor: pointer;
    }

    .spot-card-header {
      display: flex;
      justify-content: space-between;
      gap: 10px;
      align-items: flex-start;
    }

    .spot-card-title {
      margin: 0;
      font-size: 15px;
    }

    .meta {
      color: var(--muted);
      font-size: 12px;
      margin-top: 6px;
    }

    .tag {
      display: inline-block;
      border-radius: 999px;
      font-size: 11px;
      font-weight: 700;
      padding: 5px 8px;
      color: white;
      white-space: nowrap;
    }

    .tag.top { background: var(--blue); }
    .tag.sympa { background: var(--green); }
    .tag.bof { background: var(--orange); }
    .tag.nul { background: var(--red); }

    .photos-grid {
      display: grid;
      grid-template-columns: repeat(2, 1fr);
      gap: 8px;
      margin-top: 10px;
    }

    .photos-grid img {
      width: 100%;
      aspect-ratio: 1 / 1;
      object-fit: cover;
      border-radius: 12px;
      border: 1px solid var(--border);
      background: #dfe7e1;
    }

    .modal-backdrop {
      position: absolute;
      inset: 0;
      background: rgba(15, 20, 18, 0.42);
      z-index: 1200;
      display: none;
      align-items: center;
      justify-content: center;
      padding: 16px;
    }

    .modal-backdrop.open {
      display: flex;
    }

    .modal {
      width: min(680px, 100%);
      max-height: 92vh;
      overflow: auto;
      background: #fff;
      border-radius: 24px;
      box-shadow: var(--shadow);
      padding: 18px;
    }

    .modal-header {
      display: flex;
      justify-content: space-between;
      align-items: center;
      gap: 12px;
      margin-bottom: 12px;
    }

    .modal-header h2 {
      margin: 0;
      font-size: 20px;
    }

    .close-btn {
      width: 40px;
      height: 40px;
      border-radius: 50%;
      padding: 0;
      background: #f3f5f4;
      color: var(--text);
      box-shadow: none;
      border: 1px solid var(--border);
    }

    .grid {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 12px;
    }

    .field {
      display: flex;
      flex-direction: column;
      gap: 6px;
      margin-bottom: 12px;
    }

    .field.full { grid-column: 1 / -1; }

    label {
      font-size: 13px;
      font-weight: 700;
      color: var(--text);
    }

    input,
    select,
    textarea {
      width: 100%;
      border: 1px solid var(--border);
      border-radius: 14px;
      padding: 12px;
      font-size: 14px;
      background: white;
      color: var(--text);
    }

    textarea {
      min-height: 110px;
      resize: vertical;
    }

    .color-picker {
      display: flex;
      flex-wrap: wrap;
      gap: 8px;
    }

    .color-option {
      border: 1px solid var(--border);
      border-radius: 999px;
      padding: 10px 12px;
      background: white;
      cursor: pointer;
      font-size: 13px;
      font-weight: 700;
    }

    .color-option.active {
      outline: 2px solid #183026;
      outline-offset: 1px;
    }

    .modal-actions {
      display: flex;
      gap: 10px;
      justify-content: flex-end;
      flex-wrap: wrap;
      margin-top: 10px;
    }

    .status {
      font-size: 12px;
      color: var(--muted);
      margin-top: 6px;
    }

    .empty {
      color: var(--muted);
      font-size: 13px;
      padding: 8px 2px;
    }

    .linklike {
      color: #1f6b4f;
      text-decoration: underline;
      cursor: pointer;
      background: none;
      border: none;
      padding: 0;
      box-shadow: none;
      font-size: 12px;
      font-weight: 700;
    }

    @media (max-width: 920px) {
      .sidepanel {
        width: calc(100vw - 28px);
        height: 38vh;
        top: auto;
        right: 14px;
        bottom: 18px;
      }

      .legend {
        top: 76px;
        bottom: auto;
        left: 14px;
      }
    }

    @media (max-width: 640px) {
      .topbar {
        flex-direction: column;
        align-items: stretch;
      }

      .brand {
        max-width: 100%;
        border-radius: 22px;
      }

      .actions {
        justify-content: flex-end;
      }

      .legend {
        display: none;
      }

      .sidepanel {
        top: auto;
        bottom: 14px;
        left: 14px;
        right: 14px;
        width: auto;
        height: 40vh;
      }

      .grid {
        grid-template-columns: 1fr;
      }
    }
  </style></head>
<body>
  <div id="app">
    <div id="map"></div><div class="topbar">
  <div class="brand">
    <div class="dot blue"></div>
    <div>
      <h1>BreizhMap</h1>
      <small>Carte sensible de vos lieux bretons</small>
    </div>
  </div>

  <div class="actions">
    <button class="btn-secondary" id="gpsBtn">📍 Position actuelle</button>
    <button class="btn-primary" id="addBtn">➕ Ajouter un lieu</button>
  </div>
</div>

<div class="legend">
  <h3>Légende</h3>
  <div class="legend-item"><span class="dot blue"></span> Top</div>
  <div class="legend-item"><span class="dot green"></span> Sympa</div>
  <div class="legend-item"><span class="dot orange"></span> Bof</div>
  <div class="legend-item"><span class="dot red"></span> Nul</div>
</div>

<aside class="sidepanel">
  <h3>Vos lieux</h3>
  <div class="filters" id="filters"></div>
  <div class="spot-list" id="spotList"></div>
</aside>

<div class="modal-backdrop" id="modalBackdrop">
  <div class="modal">
    <div class="modal-header">
      <h2 id="modalTitle">Ajouter un lieu</h2>
      <button class="close-btn" id="closeModalBtn">✕</button>
    </div>

    <div class="grid">
      <div class="field full">
        <label for="spotName">Nom du lieu</label>
        <input id="spotName" type="text" placeholder="Ex. Pointe du Raz" />
      </div>

      <div class="field">
        <label>Date</label>
        <input id="spotDate" type="date" />
      </div>

      <div class="field">
        <label>Marée</label>
        <select id="spotTide">
          <option value="haute">Marée haute</option>
          <option value="basse">Marée basse</option>
          <option value="mi">Mi-marée</option>
          <option value="inconnue">Inconnue</option>
        </select>
      </div>

      <div class="field full">
        <label>Appréciation</label>
        <div class="color-picker" id="colorPicker"></div>
      </div>

      <div class="field full">
        <label for="spotNotes">Notes / ressenti</label>
        <textarea id="spotNotes" placeholder="Ce qui vous a marqué, l'ambiance, le vent, la lumière, un détail... "></textarea>
      </div>

      <div class="field">
        <label for="spotLat">Latitude</label>
        <input id="spotLat" type="number" step="any" placeholder="48.12345" />
      </div>

      <div class="field">
        <label for="spotLng">Longitude</label>
        <input id="spotLng" type="number" step="any" placeholder="-3.45678" />
      </div>

      <div class="field full">
        <label for="spotPhotos">Photos</label>
        <input id="spotPhotos" type="file" accept="image/*" multiple />
        <div class="status">Tu peux en mettre plusieurs. Elles seront envoyées dans le bucket Supabase.</div>
      </div>
    </div>

    <div class="modal-actions">
      <button class="btn-secondary" id="cancelBtn">Annuler</button>
      <button class="btn-primary" id="saveBtn">Enregistrer</button>
    </div>

    <div class="status" id="formStatus"></div>
  </div>
</div>

  </div>  <script src="https://unpkg.com/leaflet@1.9.4/dist/leaflet.js"></script>  <script src="https://unpkg.com/leaflet.markercluster@1.5.3/dist/leaflet.markercluster.js"></script>  <script src="https://cdn.jsdelivr.net/npm/@supabase/supabase-js@2"></script>  <script>
    // =========================
    // CONFIG SUPABASE
    // =========================
    const SUPABASE_URL = "REMPLACE_MOI";
    const SUPABASE_ANON_KEY = "REMPLACE_MOI";
    const STORAGE_BUCKET = "breizhmap-photos";

    const supabaseClient = window.supabase.createClient(SUPABASE_URL, SUPABASE_ANON_KEY);

    // =========================
    // CONSTANTES
    // =========================
    const BRITTANY_CENTER = [48.15, -2.9];
    const BRITTANY_ZOOM = 8;

    const RATINGS = {
      top: { label: "Top", color: "#2563eb", className: "top" },
      sympa: { label: "Sympa", color: "#16a34a", className: "sympa" },
      bof: { label: "Bof", color: "#f97316", className: "bof" },
      nul: { label: "Nul", color: "#dc2626", className: "nul" },
    };

    const TIDE_LABELS = {
      haute: "Marée haute",
      basse: "Marée basse",
      mi: "Mi-marée",
      inconnue: "Inconnue",
    };

    // =========================
    // ETAT
    // =========================
    let spots = [];
    let activeFilter = "all";
    let pendingCoords = null;
    let addMode = false;
    let markerLayer = null;
    let editingSpotId = null;

    // =========================
    // DOM
    // =========================
    const spotListEl = document.getElementById("spotList");
    const filtersEl = document.getElementById("filters");
    const modalBackdrop = document.getElementById("modalBackdrop");
    const modalTitle = document.getElementById("modalTitle");
    const formStatus = document.getElementById("formStatus");

    const spotNameEl = document.getElementById("spotName");
    const spotDateEl = document.getElementById("spotDate");
    const spotTideEl = document.getElementById("spotTide");
    const spotNotesEl = document.getElementById("spotNotes");
    const spotLatEl = document.getElementById("spotLat");
    const spotLngEl = document.getElementById("spotLng");
    const spotPhotosEl = document.getElementById("spotPhotos");

    // =========================
    // CARTE
    // =========================
    const map = L.map("map", { zoomControl: true }).setView(BRITTANY_CENTER, BRITTANY_ZOOM);

    L.tileLayer("https://{s}.tile.openstreetmap.org/{z}/{x}/{y}.png", {
      maxZoom: 19,
      attribution: '&copy; OpenStreetMap contributors'
    }).addTo(map);

    markerLayer = L.markerClusterGroup();
    map.addLayer(markerLayer);

    map.on("click", (e) => {
      if (!addMode) return;
      addMode = false;
      pendingCoords = { lat: e.latlng.lat, lng: e.latlng.lng };
      openModalForCreate(pendingCoords);
    });

    // =========================
    // UI INIT
    // =========================
    function buildFilters() {
      const defs = [
        { value: "all", label: "Tous" },
        { value: "top", label: "Top" },
        { value: "sympa", label: "Sympa" },
        { value: "bof", label: "Bof" },
        { value: "nul", label: "Nul" },
      ];

      filtersEl.innerHTML = defs.map(def => `
        <button class="chip ${activeFilter === def.value ? 'active' : ''}" data-filter="${def.value}">${def.label}</button>
      `).join("");

      filtersEl.querySelectorAll(".chip").forEach(btn => {
        btn.addEventListener("click", () => {
          activeFilter = btn.dataset.filter;
          buildFilters();
          renderList();
          renderMarkers();
        });
      });
    }

    function buildColorPicker(selected = "top") {
      const picker = document.getElementById("colorPicker");
      picker.innerHTML = Object.entries(RATINGS).map(([value, cfg]) => `
        <button type="button" class="color-option ${selected === value ? 'active' : ''}" data-rating="${value}" style="color:${cfg.color}">
          ● ${cfg.label}
        </button>
      `).join("");

      picker.querySelectorAll(".color-option").forEach(btn => {
        btn.addEventListener("click", () => {
          picker.querySelectorAll(".color-option").forEach(b => b.classList.remove("active"));
          btn.classList.add("active");
        });
      });
    }

    function getSelectedRating() {
      const active = document.querySelector("#colorPicker .color-option.active");
      return active ? active.dataset.rating : "top";
    }

    function openModal() {
      modalBackdrop.classList.add("open");
    }

    function closeModal() {
      modalBackdrop.classList.remove("open");
      formStatus.textContent = "";
      editingSpotId = null;
      pendingCoords = null;
      spotPhotosEl.value = "";
    }

    function resetForm() {
      spotNameEl.value = "";
      spotDateEl.value = new Date().toISOString().slice(0, 10);
      spotTideEl.value = "inconnue";
      spotNotesEl.value = "";
      spotLatEl.value = "";
      spotLngEl.value = "";
      buildColorPicker("top");
      formStatus.textContent = "";
    }

    function openModalForCreate(coords = null) {
      editingSpotId = null;
      modalTitle.textContent = "Ajouter un lieu";
      resetForm();
      if (coords) {
        spotLatEl.value = coords.lat;
        spotLngEl.value = coords.lng;
      }
      openModal();
    }

    function openModalForEdit(spot) {
      editingSpotId = spot.id;
      modalTitle.textContent = "Modifier un lieu";
      spotNameEl.value = spot.name || "";
      spotDateEl.value = spot.visit_date || new Date().toISOString().slice(0, 10);
      spotTideEl.value = spot.tide || "inconnue";
      spotNotesEl.value = spot.notes || "";
      spotLatEl.value = spot.lat;
      spotLngEl.value = spot.lng;
      buildColorPicker(spot.rating || "top");
      formStatus.textContent = "Les nouvelles photos seront ajoutées aux anciennes.";
      openModal();
    }

    // =========================
    // RENDER
    // =========================
    function getFilteredSpots() {
      const sorted = [...spots].sort((a, b) => new Date(b.visit_date) - new Date(a.visit_date));
      if (activeFilter === "all") return sorted;
      return sorted.filter(s => s.rating === activeFilter);
    }

    function renderList() {
      const filtered = getFilteredSpots();
      if (!filtered.length) {
        spotListEl.innerHTML = `<div class="empty">Aucun lieu pour ce filtre pour l’instant.</div>`;
        return;
      }

      spotListEl.innerHTML = filtered.map(spot => {
        const cfg = RATINGS[spot.rating] || RATINGS.top;
        const firstPhotos = (spot.photo_urls || []).slice(0, 4).map(url => `<img src="${url}" alt="${escapeHtml(spot.name)}">`).join("");
        return `
          <div class="spot-card" data-id="${
